import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner scn = new Scanner(System.in);
      String s = scn.nextLine();
      Set<Character> set = new HashSet<>();
      StringBuilder ans = new StringBuilder();
      for(char ch : s.toCharArray()){
        if(!set.contains(ch)){
          set.add(ch);
          ans.append(ch);
        }
      }
      System.out.print(ans);
    }
}
