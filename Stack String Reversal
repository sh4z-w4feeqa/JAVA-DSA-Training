import java.util.*;
public class Main {
    public static void main(String[] args) {
      Scanner scn = new Scanner(System.in);
      Stack<Character> stack = new Stack<>();
      String rev = "", s = scn.nextLine();
      for(int i = 0; i<s.length(); i++)
        stack.push(s.charAt(i);
      while(!stack.isEmpty())
        rev+=stack.pop();
      System.out.print(rev);
}}
