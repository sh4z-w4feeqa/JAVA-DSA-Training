import java.util.*;
class Node{
  int data;
  Node left, right;
  Node(int data){
    this.data = data;
    this.left = null;
    this.right = right;
}}
public class Main{
  static Node buildTree(Scanner scn){
    int val = scn.nextInt();
    if(val==-1) return null;
    Node root = new Node(val);
    Queue<Node> q = new LinkedList<>();
    q.add(root);
    while(!q.isEmpty()){
      Node temp = q.poll();
      int leftval = scn.nextInt();
      if(leftval!=-1){
        temp.left = new Node(leftval);
        q.add(temp.left);
      }
      int rightval = scn.nextInt();
      if(rightval!=-1){
        temp.right = new Node(rightval);
        q.add(temp.right);
      }
    }
    return root;
  }
  static int count = 0;
  static int sum = 0;
  static void inorder(Node root){
    if(root!=null){
      inorder(root.left);
      count++;
      sum+=root.data;
      inorder(root.right);
}}
  
  public static void main(String[] args){
    Scanner scn = new Scanner(System.in);
    Node root = buildTree(scn);
    inorder(root);
    System.out.print(count+" ");
    System.out.print(sum+" ");
}}
