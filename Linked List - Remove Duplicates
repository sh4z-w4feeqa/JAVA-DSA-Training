import java.util.*;
class Node{
  int data;
  Node next;
  Node(int data){
    this.data = data;
    this.next = null;
  }
}
class Singly{
  Node head, tail;
  Singly(){
    head = null;
    tail = null;
  }
   void create(int num){
    Node newNode = new Node(num);
    if(head == null){
      head = newNode;
      tail = newNode;
    }
    else{
      tail.next = newNode;
      tail = newNode;
    }
  }
  void remove(){
    Node itr = head;
    while(itr!=null && itr.next!=null){
      if(itr.data == itr.next.data) 
        itr.next = itr.next.next;
      else 
        itr = itr.next;
    }
    itr = head;
    while(itr != null){
        System.out.print(itr.data);
        if(itr.next != null) {
            System.out.print("->");
        }
        itr = itr.next;
    }
  }
}

public class Main{
  public static void main(String[] args){
    Scanner scn = new Scanner(System.in);
    Singly s = new Singly();
    int n = scn.nextInt();
    int num;
    for(int i = 0; i<n; i++){
      num = scn.nextInt();
      s.create(num);
    }
    s.remove();
}
}
